# Edge Agent configuration — copy to .env and fill in values

# Control Center API base URL
AGENT_CONTROL_CENTER_URL=http://127.0.0.1:8001

# Agent token (shown once when creating a client in Control Center UI)
AGENT_TOKEN=

# Heartbeat interval in seconds (default: 60)
AGENT_HEARTBEAT_INTERVAL=60

# Version strings reported to Control Center
AGENT_AGENT_VERSION=1.0.0
AGENT_ERP_VERSION=1.0.0

# Optional: override instance ID (auto-generated if empty)
# AGENT_INSTANCE_ID=

# Local data directory for persisted instance ID
AGENT_DATA_DIR=.agent-data
