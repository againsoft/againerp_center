# Railway — API service (Root Directory: apps/api)
APP_NAME=AgainERP Control Center
APP_ENV=production
SECRET_KEY=generate-a-long-random-string-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Set automatically when PostgreSQL plugin is linked:
# DATABASE_URL=${{Postgres.DATABASE_URL}}

# Your public Web URL (comma-separated if multiple):
CORS_ORIGINS=https://your-web-service.up.railway.app

MFA_ENFORCE=false
SEED_DEMO_DATA=false
INITIAL_ADMIN_EMAIL=admin@yourcompany.com
INITIAL_ADMIN_PASSWORD=change-me-strong-password
STRIPE_WEBHOOK_SECRET=
