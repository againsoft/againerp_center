{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://againerp.com/schemas/contracts/conversation-request.v1.json",
  "title": "ConversationRequest",
  "description": "Runtime → Center conversation request (contract v1.0.0)",
  "type": "object",
  "required": ["contractVersion", "clientId", "module", "prompt", "messages", "promptStack", "sessionMemory"],
  "properties": {
    "contractVersion": { "type": "string", "const": "1.0.0" },
    "clientId": { "type": "string", "minLength": 1 },
    "tenantId": { "type": "string" },
    "conversationId": { "type": "string" },
    "sessionId": { "type": "string" },
    "userId": { "type": "string" },
    "module": {
      "type": "string",
      "enum": [
        "pc_builder",
        "laptop_builder",
        "server_builder",
        "nas_builder",
        "networking_builder",
        "cctv_builder",
        "workstation_builder",
        "storefront_chat",
        "admin_assistant"
      ]
    },
    "prompt": { "type": "string" },
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "content"],
        "properties": {
          "role": { "type": "string", "enum": ["user", "assistant", "system"] },
          "content": { "type": "string" }
        }
      }
    },
    "promptStack": {
      "type": "object",
      "properties": {
        "system": { "type": "string" },
        "global": { "type": "string" },
        "module": { "type": "string" },
        "client": { "type": "string" }
      }
    },
    "sessionMemory": { "type": "object", "additionalProperties": true },
    "pageContext": {
      "type": "object",
      "required": ["surface", "page"],
      "properties": {
        "surface": { "type": "string" },
        "page": { "type": "string" },
        "entityType": { "type": "string" },
        "entityId": { "type": "string" },
        "metadata": { "type": "object", "additionalProperties": true }
      }
    },
    "catalogSummary": { "type": "string" },
    "currentBuild": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stepId", "productId"],
        "properties": {
          "stepId": { "type": "string" },
          "productId": { "type": "string" }
        }
      }
    },
    "metadata": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": false
}
