{
  "name": "@againerp/contracts",
  "version": "1.0.0",
  "description": "AgainERP platform shared contracts — DTOs, events, schemas (lives in againerp-center)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./providers": {
      "types": "./dist/providers.d.ts",
      "import": "./dist/providers.js"
    },
    "./agents": {
      "types": "./dist/agents.d.ts",
      "import": "./dist/agents.js"
    },
    "./conversation": {
      "types": "./dist/conversation.d.ts",
      "import": "./dist/conversation.js"
    },
    "./context": {
      "types": "./dist/context.d.ts",
      "import": "./dist/context.js"
    },
    "./events": {
      "types": "./dist/events.d.ts",
      "import": "./dist/events.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./version": {
      "types": "./dist/version.d.ts",
      "import": "./dist/version.js"
    },
    "./ids": {
      "types": "./dist/ids.d.ts",
      "import": "./dist/ids.js"
    },
    "./types": {
      "types": "./dist/types/ids.d.ts",
      "import": "./dist/types/ids.js"
    },
    "./dto": {
      "types": "./dist/dto/conversation.d.ts",
      "import": "./dist/dto/conversation.js"
    },
    "./protocols": {
      "types": "./dist/protocols/providers.d.ts",
      "import": "./dist/protocols/providers.js"
    },
    "./interfaces": {
      "types": "./dist/interfaces/index.d.ts",
      "import": "./dist/interfaces/index.js"
    },
    "./permissions": {
      "types": "./dist/permissions/index.d.ts",
      "import": "./dist/permissions/index.js"
    }
  },
  "files": ["dist", "schemas"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  },
  "license": "UNLICENSED",
  "private": true
}
